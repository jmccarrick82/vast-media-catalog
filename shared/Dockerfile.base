FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY shared/ /app/shared/

RUN pip install --no-cache-dir \
    vastdb \
    pyarrow \
    boto3 \
    imagehash \
    Pillow \
    numpy

ENV PYTHONPATH=/app
